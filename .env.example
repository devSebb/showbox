DATABASE_URL=postgresql://user:pass@host:5432/showbox
SESSION_SECRET=generate-a-secure-random-string
ADMIN_INITIAL_PASSWORD=your-secure-admin-password
NODE_ENV=production

# Contact form: Gmail SMTP (use App Password for zalam.showbox@gmail.com)
# CONTACT_SMTP_USER=zalam.showbox@gmail.com
# CONTACT_SMTP_PASS=your-gmail-app-password

# Optional: Cloudflare R2 for persistent media storage (recommended for production)
# Without R2, uploaded files are stored on disk and will be lost on server restart.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=
# R2_PUBLIC_BASE_URL=
